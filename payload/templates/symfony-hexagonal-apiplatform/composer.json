{
    "name": "app/__PROJECT_NAME__",
    "description": "__PROJECT_DESCRIPTION__",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "api-platform/core": "^4",
        "doctrine/dbal": "^4",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "7.4.*",
        "symfony/messenger": "7.4.*",
        "symfony/property-access": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2",
        "phpstan/phpstan-doctrine": "^2",
        "phpstan/phpstan-strict-rules": "^2",
        "phpstan/phpstan-symfony": "^2",
        "phpunit/phpunit": "^11.5",
        "symfony/browser-kit": "7.4.*",
        "symfony/phpunit-bridge": "^7.4"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "stan": [
            "@php bin/console cache:warmup --env=dev --quiet",
            "phpstan analyse"
        ],
        "test": "phpunit",
        "check": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
