# Copy the values you need to override into `.env.local` (git-ignored).
# This file documents the variables the app reads; never put real secrets here.
#
# APP_ENV=dev
# APP_SECRET=
# DATABASE_URL="postgresql://app:app@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
# MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
