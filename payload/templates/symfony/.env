# Default, non-secret environment values — committed on purpose (Symfony convention).
# Real secrets go in `.env.local` (git-ignored) or the Symfony secrets vault.
# See https://symfony.com/doc/current/configuration.html#configuration-environments

APP_ENV=dev
APP_SECRET=change_me_in_env_local

# Doctrine — override in `.env.local`. Defaults to a local SQLite file so the
# project boots and tests run without a database server.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"

# Messenger — sync transport by default (no broker required to get started).
MESSENGER_TRANSPORT_DSN=sync://
